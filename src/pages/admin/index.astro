---
export const prerender = false;
import '../../styles/global.css';
// The admin is a client-rendered SPA (auth happens in the browser against the
// same-origin teenybase API). We ship a minimal SSR shell + mount point.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin — anks.in</title>
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-surface text-ink">
    <div id="admin-root" class="adm-root">
      <div class="adm-boot">Loading admin…</div>
    </div>
    <script>
      import { AdminApp } from '../../lib/admin/app';
      const root = document.getElementById('admin-root');
      if (root) new AdminApp(root);
    </script>
  </body>
</html>

<style is:global>
  :root {
    --adm-radius: 10px;
  }
  .adm-root { min-height: 100vh; }
  .adm-boot { display: grid; place-items: center; min-height: 100vh; color: var(--color-ink-tertiary); font-family: var(--font-mono, monospace); }

  /* Buttons */
  .adm-btn { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1rem; border-radius: 8px; border: 1px solid var(--color-border); background: var(--color-surface-raised); color: var(--color-ink); font: inherit; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all .15s; }
  .adm-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .adm-btn-primary { background: var(--color-accent); color: var(--color-ink-on-dark, #fff); border-color: var(--color-accent); }
  .adm-btn-primary:hover { filter: brightness(1.08); color: var(--color-ink-on-dark, #fff); }
  .adm-btn-block { width: 100%; justify-content: center; margin-top: .5rem; }
  .adm-danger-btn { color: #c0392b; border-color: #e7b9b3; }
  .adm-danger-btn:hover { background: #c0392b; color: #fff; border-color: #c0392b; }

  /* Auth */
  .adm-auth { min-height: 100vh; display: grid; place-items: center; padding: 2rem; }
  .adm-auth-card { width: 100%; max-width: 380px; background: var(--color-surface-raised); border: 1px solid var(--color-border); border-radius: var(--adm-radius); padding: 2rem; display: flex; flex-direction: column; }
  .adm-auth-title { font-family: var(--font-display, inherit); font-size: 24px; font-weight: 700; margin: 0 0 .25rem; }
  .adm-auth-sub { color: var(--color-ink-secondary); margin: 0 0 1.25rem; font-size: 14px; }

  /* Inputs */
  .adm-label { display: block; font-size: 13px; font-weight: 600; color: var(--color-ink-secondary); margin: .9rem 0 .35rem; }
  .adm-req { color: #c0392b; }
  .adm-input { width: 100%; box-sizing: border-box; padding: .6rem .7rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface); color: var(--color-ink); font: inherit; font-size: 14px; transition: border-color .15s; }
  .adm-input:focus { outline: none; border-color: var(--color-accent); }
  .adm-textarea { min-height: 90px; resize: vertical; line-height: 1.6; }
  .adm-mono { font-family: var(--font-mono, monospace); font-size: 13px; }
  .adm-help { font-size: 12px; color: var(--color-ink-tertiary); margin: .35rem 0 0; }
  .adm-error { background: #fdecea; color: #c0392b; border: 1px solid #f5c6cb; padding: .6rem .75rem; border-radius: 8px; font-size: 13px; margin-bottom: .5rem; }
  .adm-error-inline { color: #c0392b; font-size: 13px; }
  .adm-ok { color: #2d8a56; font-size: 13px; font-weight: 600; }

  /* Shell */
  .adm-shell { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
  .adm-side { border-right: 1px solid var(--color-border); padding: 1.25rem 1rem; display: flex; flex-direction: column; gap: .25rem; background: var(--color-surface-sunken); position: sticky; top: 0; height: 100vh; box-sizing: border-box; }
  .adm-brand { font-family: var(--font-display, inherit); font-weight: 700; font-size: 18px; margin-bottom: 1rem; }
  .adm-brand span { color: var(--color-accent); }
  .adm-nav { display: flex; flex-direction: column; gap: .15rem; }
  .adm-nav-link { display: flex; align-items: center; justify-content: space-between; padding: .5rem .65rem; border-radius: 8px; color: var(--color-ink-secondary); text-decoration: none; font-size: 14px; font-weight: 500; background: none; border: none; cursor: pointer; text-align: left; width: 100%; box-sizing: border-box; }
  .adm-nav-link:hover { background: var(--color-surface-raised); color: var(--color-ink); }
  .adm-active { background: var(--color-accent-wash); color: var(--color-accent); font-weight: 600; }
  .adm-nav-disabled { opacity: .55; }
  .adm-soon { font-size: 10px; text-transform: uppercase; letter-spacing: .05em; background: var(--color-border); color: var(--color-ink-tertiary); padding: .1rem .35rem; border-radius: 4px; }
  .adm-side-foot { margin-top: auto; border-top: 1px solid var(--color-border); padding-top: .5rem; }
  .adm-logout { color: var(--color-ink-tertiary); }
  .adm-main { padding: 1.75rem 2rem; max-width: 1000px; }

  /* Head */
  .adm-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
  .adm-head h1 { font-family: var(--font-display, inherit); font-size: 26px; font-weight: 700; margin: 0; }
  .adm-head-left { display: flex; flex-direction: column; gap: .2rem; }
  .adm-head-actions { display: flex; gap: .5rem; }
  .adm-back { font-size: 13px; color: var(--color-accent); text-decoration: none; }

  /* Table */
  .adm-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .adm-table th { text-align: left; padding: .5rem .6rem; color: var(--color-ink-tertiary); font-size: 12px; text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid var(--color-border); }
  .adm-table td { padding: .65rem .6rem; border-bottom: 1px solid var(--color-border); color: var(--color-ink-secondary); }
  .adm-link { color: var(--color-ink); font-weight: 600; text-decoration: none; }
  .adm-link:hover { color: var(--color-accent); }
  .adm-row-actions { text-align: right; white-space: nowrap; }
  .adm-icon-btn { display: inline-block; padding: .25rem .45rem; border-radius: 6px; border: none; background: none; cursor: pointer; text-decoration: none; font-size: 14px; color: var(--color-ink-tertiary); }
  .adm-icon-btn:hover { background: var(--color-surface-sunken); color: var(--color-ink); }
  .adm-danger:hover { color: #c0392b; }

  /* Empty */
  .adm-empty { text-align: center; padding: 3rem 1rem; border: 1px dashed var(--color-border); border-radius: var(--adm-radius); color: var(--color-ink-secondary); display: flex; flex-direction: column; align-items: center; gap: .5rem; }

  /* Form */
  .adm-field { margin-bottom: 1.1rem; }
  .adm-switch { display: inline-flex; align-items: center; gap: .5rem; cursor: pointer; font-size: 14px; font-weight: 500; }
  .adm-switch input { width: 18px; height: 18px; accent-color: var(--color-accent); }
  .adm-save-bar { position: sticky; bottom: 0; padding: .5rem 0; min-height: 1.5rem; }

  /* Tags */
  .adm-tags { border: 1px solid var(--color-border); border-radius: 8px; padding: .35rem; background: var(--color-surface); }
  .adm-tags-pills { display: flex; flex-wrap: wrap; gap: .35rem; }
  .adm-pill { display: inline-flex; align-items: center; gap: .3rem; background: var(--color-accent-wash); color: var(--color-accent); border-radius: 6px; padding: .2rem .5rem; font-size: 13px; font-weight: 500; }
  .adm-pill button { border: none; background: none; color: inherit; cursor: pointer; font-size: 14px; line-height: 1; }
  .adm-tags-input { border: none; outline: none; background: none; padding: .3rem .4rem; font: inherit; font-size: 14px; color: var(--color-ink); flex: 1; min-width: 120px; }

  /* Image field */
  .adm-image-drop { font-size: 12px; color: var(--color-ink-tertiary); padding: .5rem; border: 1px dashed var(--color-border); border-radius: 8px; text-align: center; margin-top: .5rem; }
  .adm-image.adm-dragging .adm-image-drop { border-color: var(--color-accent); color: var(--color-accent); }
  .adm-image-preview img { max-width: 220px; border-radius: 8px; border: 1px solid var(--color-border); margin-top: .5rem; }

  /* Markdown editor */
  .md-editor { border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; background: var(--color-surface); }
  .md-toolbar { display: flex; align-items: center; gap: .15rem; padding: .35rem .5rem; border-bottom: 1px solid var(--color-border); background: var(--color-surface-sunken); flex-wrap: wrap; }
  .md-toolbar button { min-width: 30px; height: 30px; padding: 0 .4rem; border: 1px solid transparent; border-radius: 6px; background: none; cursor: pointer; color: var(--color-ink-secondary); font-size: 14px; }
  .md-toolbar button:hover { background: var(--color-surface-raised); border-color: var(--color-border); color: var(--color-ink); }
  .md-sep { width: 1px; height: 20px; background: var(--color-border); margin: 0 .25rem; }
  .md-spacer { flex: 1; }
  .md-toggle { font-size: 12px !important; font-weight: 600; }
  .md-panes { display: grid; grid-template-columns: 1fr 1fr; min-height: 360px; }
  .md-input { border: none; outline: none; resize: vertical; padding: 1rem; font-family: var(--font-mono, monospace); font-size: 14px; line-height: 1.7; background: var(--color-surface); color: var(--color-ink); min-height: 360px; }
  .md-preview { padding: 1rem 1.25rem; border-left: 1px solid var(--color-border); overflow-y: auto; max-height: 600px; background: var(--color-surface-raised); }
  .md-editor.md-preview-only .md-input { display: none; }
  .md-editor.md-preview-only .md-preview { border-left: none; }
  .md-editor.md-dragging { outline: 2px dashed var(--color-accent); outline-offset: -2px; }
  .md-drop-hint { display: none; }
  @media (max-width: 720px) {
    .adm-shell { grid-template-columns: 1fr; }
    .adm-side { position: static; height: auto; flex-direction: row; flex-wrap: wrap; align-items: center; }
    .adm-nav { flex-direction: row; flex-wrap: wrap; }
    .adm-side-foot { margin: 0; border: none; padding: 0; }
    .md-panes { grid-template-columns: 1fr; }
    .md-preview { border-left: none; border-top: 1px solid var(--color-border); }
    .adm-main { padding: 1rem; }
  }

  /* Post body (shared preview typography) */
  .post-body h2 { font-size: 20px; font-weight: 700; margin: 1.5rem 0 .5rem; color: var(--color-ink); }
  .post-body h3 { font-size: 17px; font-weight: 600; margin: 1.2rem 0 .4rem; color: var(--color-ink); }
  .post-body p { font-size: 15px; line-height: 1.7; color: var(--color-ink-secondary); margin: 0 0 .8rem; }
  .post-body ul, .post-body ol { font-size: 15px; color: var(--color-ink-secondary); line-height: 1.7; padding-left: 1.3rem; }
  .post-body a { color: var(--color-accent); }
  .post-body code { font-family: var(--font-mono, monospace); font-size: .9em; background: var(--color-accent-wash); color: var(--color-accent); padding: .1em .35em; border-radius: 4px; }
  .post-body pre { background: var(--color-surface-sunken); border: 1px solid var(--color-border); border-radius: 8px; padding: .85rem 1rem; overflow-x: auto; }
  .post-body pre code { background: none; color: var(--color-ink); padding: 0; }
  .post-body img { max-width: 100%; border-radius: 8px; }
  .post-body blockquote { border-left: 3px solid var(--color-accent); padding-left: 1rem; color: var(--color-ink-tertiary); margin: 0 0 .8rem; }

  /* Skeletons */
  .adm-skel-list { display: flex; flex-direction: column; gap: .6rem; }
  .adm-skel-row { height: 44px; border-radius: 8px; background: linear-gradient(90deg, var(--color-surface-sunken) 25%, var(--color-surface-raised) 37%, var(--color-surface-sunken) 63%); background-size: 400% 100%; animation: adm-shimmer 1.4s ease infinite; }
  @keyframes adm-shimmer { 0% { background-position: 100% 50%; } 100% { background-position: 0 50%; } }
</style>
